# Copy this to .env and fill in real values
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///./bachelor_finance.db

# CORS: comma-separated list of allowed frontend URLs
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Resend (for email reports) - https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# VAPID keys for Web Push notifications
# Generate with: python -c "from py_vapid import Vapid01; v=Vapid01(); v.generate_keys(); v.save_key('vapid_private.pem'); print(v.public_key)"
VAPID_PRIVATE_KEY_PATH=vapid_private.pem
VAPID_PUBLIC_KEY=
VAPID_EMAIL=mailto:you@example.com
